{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "768px",
			"wideSize": "1200px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{ "slug": "crimson", "color": "#9d1c2b", "name": "ครั่ง (Crimson)" },
				{ "slug": "crimson-dark", "color": "#7c2021", "name": "ครั่งเข้ม (Crimson dark)" },
				{ "slug": "plum", "color": "#2f2b3d", "name": "พลัม (Slate-plum)" },
				{ "slug": "gold", "color": "#b8862b", "name": "ทอง (Gold)" },
				{ "slug": "paper", "color": "#f0f0f4", "name": "พื้นเทา (Paper)" },
				{ "slug": "paper-light", "color": "#f8f7fa", "name": "พื้นอ่อน (Paper light)" },
				{ "slug": "ink", "color": "#2f2b3d", "name": "หมึก (Ink)" },
				{ "slug": "success", "color": "#28c76f", "name": "สำเร็จ (Success)" },
				{ "slug": "warning", "color": "#ff9f43", "name": "เตือน (Warning)" },
				{ "slug": "danger", "color": "#ff4c51", "name": "อันตราย (Danger)" },
				{ "slug": "info", "color": "#00bad1", "name": "ข้อมูล (Info)" },
				{ "slug": "white", "color": "#ffffff", "name": "ขาว (White)" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "Anuphan, Sarabun, system-ui, sans-serif",
					"slug": "sans",
					"name": "Anuphan (เนื้อหา)"
				},
				{
					"fontFamily": "Anuphan, Sarabun, system-ui, sans-serif",
					"slug": "serif",
					"name": "Anuphan (หัวข้อ)"
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "0.875rem", "name": "เล็ก" },
				{ "slug": "medium", "size": "1.0625rem", "name": "ปกติ" },
				{ "slug": "large", "size": "1.375rem", "name": "ใหญ่" },
				{ "slug": "x-large", "size": "2rem", "name": "ใหญ่มาก" },
				{ "slug": "xx-large", "size": "2.75rem", "name": "พาดหัว" }
			]
		},
		"spacing": {
			"units": [ "px", "em", "rem", "%", "vw", "vh" ]
		}
	},
	"styles": {
		"color": {
			"background": "#f8f7fa",
			"text": "#2f2b3d"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "1.0625rem",
			"lineHeight": "1.7"
		},
		"elements": {
			"link": {
				"color": { "text": "#9d1c2b" }
			},
			"h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" } },
			"h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" } },
			"h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" } },
			"h4": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" } }
		}
	}
}
