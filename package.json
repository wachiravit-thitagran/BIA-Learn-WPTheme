{
  "name": "bia-learn-theme",
  "version": "1.0.0",
  "description": "BIA Learn — WordPress theme for bia-learn.psu.ac.th (Tutor LMS + TailwindCSS)",
  "author": "Buddhadasa Indapanno Archives / PSU",
  "license": "GPL-2.0-or-later",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel watch:css watch:js",
    "watch:css": "tailwindcss -i ./src/css/main.css -o ./assets/css/main.css --watch",
    "watch:js": "esbuild ./src/js/main.js --bundle --outfile=./assets/js/main.js --watch",
    "build": "npm-run-all build:css build:js",
    "build:css": "tailwindcss -i ./src/css/main.css -o ./assets/css/main.css --minify",
    "build:js": "esbuild ./src/js/main.js --bundle --minify --outfile=./assets/js/main.js"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.21.5",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.14.1",
    "@alpinejs/focus": "^3.14.1",
    "alpinejs": "^3.14.1"
  }
}
